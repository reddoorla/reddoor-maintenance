# Required for `reddoor-maint report ...`
AIRTABLE_PAT=patXXXXXXXXXXXXXX        # personal access token with scopes: schema.bases:read, data.records:read, data.records:write
AIRTABLE_BASE_ID=appHG8nLOzULzXOER     # "Reddoor Websites" base
RESEND_API_KEY=re_XXXXXXXXXXXXXXXX     # from https://resend.com/api-keys

# Required only for the Netlify webhook (Phase 5)
RESEND_WEBHOOK_SECRET=whsec_XXXXXXXX   # from https://resend.com/webhooks
# Required for the form-ingest endpoint (gates POST /api/forms/:slug)
FORMS_INGEST_TOKEN=replace-with-a-strong-random-secret   # `openssl rand -hex 32`; the SAME value is set on each fleet site
# Fleet SITES additionally set FORMS_INGEST_URL=https://reddoor-maintenance.netlify.app/api/forms/<slug> (not read by the dashboard)

# Required by the DB-backed Netlify functions — submissions + spam counters live in
# libSQL/Turso (form-ingest, submission-status, submissions-page, fleet-homepage,
# site-dashboard). readDbConfig() THROWS if TURSO_DATABASE_URL is unset, so these
# functions 500 on first request without it. `db migrate`/`reconcile` need it too.
TURSO_DATABASE_URL=libsql://<db>-<org>.turso.io   # or file:./local.db for a local libSQL; :memory: in tests
TURSO_AUTH_TOKEN=                                  # required for a remote Turso url; omit for file:/:memory:
# DUAL_WRITE_AIRTABLE=1                             # (soak only — now retired) mirrored each write to the legacy Airtable tables
