                  "body": {
                    "__richtext_html": "<h4>a city full of possibilities</h4>
<p>Burbank offers a wide range of opportunities from its network of world-renowned studios, accessible airport, and recreational activities.</p>",
                  },
                  "body_role": "text1",
                  "embed_html": "<a class="ib middle buttons2" href="https://dv4tl7yyk1zlp.cloudfront.net/ea3c0e4e-aa87-4d1b-adaa-cb250234ec3c/1b5b96c1-16fb-4d8b-8cb0-f71938af22c0.pdf">Burbank Incentives</a>",
