                  "body": {
                    "__richtext_html": "<p>an impeccably
lush haven</p>",
                  },
                  "kind": "text",
                },
              ],
              "heading": {
                "__richtext_html": "<h2>the outdoors</h2>",
              },
              "heading_role": "text5",
            },
            "slice_type": "blux_section",
            "variation": "default",
