                      },
                      "width": "70%",
                    },
                    {
                      "body": {
                        "__richtext_html": "<p>Renew and recover with exclusive access to a state-of-the-art <a href="https://www.tbpfit.com/" class="links">FIT Health Club</a> with full-service locker rooms in a spa-like atmosphere. <br></p>",
                      },
                      "body_role": "text14",
                      "kind": "text",
                      "width": "30%",
                    },
                  ],
                },
                {
                  "kind": "subgrid",
                  "subgrid": [
                    {
                      "body": {
                        "__richtext_html": "<p>Enjoy exclusive access to on-site production and filming studios.</p>",
                      },
                      "body_role": "text14",
                      "kind": "text",
                      "width": "30%",
                    },
                    {
                      "cover": "on",
                      "kind": "media",
                      "media": {
                        "__asset_id": "2c05f47c-cfee-4383-8955-5dea66b4df15",
                      },
                      "width": "70%",
                    },
                  ],
                },
                {
                  "kind": "subgrid",
                  "subgrid": [
                    {
                      "kind": "media",
                      "media": {
                        "__asset_id": "6fefaae2-82b2-4861-9efe-b491cc3d2af1",
                      },
                      "width": "70%",
                    },
                    {
                      "body": {
                        "__richtext_html": "<p>Head to the MRKT for a quick bite on-the-go, or dine in for a filling meal.</p>",
                      },
                      "body_role": "text14",
                      "kind": "text",
                      "width": "30%",
                    },
                  ],
                },
              ],
              "columns": 1,
