            "primary": {
              "cells": [
                {
                  "body": {
                    "__richtext_html": "<h4>premium <br>amenities</h4>
<p>A campus built for the modern worker, The Pointe offers amenities that enrich the every day.</p>",
                  },
                  "body_role": "text1",
                  "kind": "text",
                  "media": {
                    "__asset_id": "ec0c6ec6-45b9-4ac8-84e5-0438c84629b9",
                  },
                  "title": {
                    "__richtext_html": "<h4>on-site luxuries</h4>",
                  },
                  "title_role": "text5",
                  "width": "60%",
                },
              ],
              "columns": 2,
            },
            "slice_type": "blux_grid",
            "variation": "default",
          },
          {
            "items": [],
            "primary": {
              "cells": [
